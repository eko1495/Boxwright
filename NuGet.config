<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Pin restores to nuget.org only. Central Package Management requires a single
    source (or source mapping), and this keeps restores reproducible regardless of
    any machine- or user-level NuGet sources.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
