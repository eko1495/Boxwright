    {
      // Pre-installed cloud image (qcow2), not an installer ISO: it is flattened into the VM disk and
      // boots straight into cloud-init, which applies the seed on first boot — a genuinely hands-free
      // install (no installer screens). Server image (no desktop). The SHA-256 below is the source of
      // truth; sizeBytes is approximate (progress only) and, like the hash, rotates each point release.
      "id": "ubuntu-24.04-server-cloudimage",
      "imageKind": "cloudimage",
      "osFamily": "ubuntu",
      "supportsAutoinstall": true,
      "name": "Ubuntu Server (cloud image)",
      "version": "24.04 LTS",
      "arch": "x86_64",
      "isoUrl": "https://cloud-images.ubuntu.com/releases/24.04/release/ubuntu-24.04-server-cloudimg-amd64.img",
      "sha256": "53fdde898feed8b027d94baa9cfe8229867f330a1d9c49dc7d84465ee7f229f7",
      "sizeBytes": 628097024,
      "recommended": { "memoryMiB": 2048, "cpuCores": 2, "diskGiB": 20, "firmware": "uefi" },
      "sourceName": "Canonical · cloud-images.ubuntu.com",
      "requiresLicense": false,
      "notes": "Hands-free: a pre-installed server image set up by cloud-init on first boot. Headless server (no desktop) — sign in at the console with the username and password you set."
    },
    {
      "id": "debian-13-netinst",
      "osFamily": "debian",
      "supportsAutoinstall": true,
      "name": "Debian",
      "version": "13.5.0 (netinst)",
      "arch": "x86_64",
      "isoUrl": "https://cdimage.debian.org/debian-cd/13.5.0/amd64/iso-cd/debian-13.5.0-amd64-netinst.iso",
      "sha256": "95838884f5ea6c82421dfe6baaa5a639dbbe6756c1e380f9fe7a7cb0c1949d2a",
      "sizeBytes": 696254464,
      "recommended": { "memoryMiB": 2048, "cpuCores": 2, "diskGiB": 20, "firmware": "uefi" },
      "sourceName": "Debian · cdimage.debian.org",
      "notes": "Network installer — needs an internet connection during installation. Unattended installs a GNOME desktop, so the first install downloads a lot of packages and takes a while.",
      // Unattended via a declarative recipe (ADR-0026): a debian-installer preseed injected into the
      // text-installer initrd, booted with auto=true priority=critical. Routes through RecipeInstaller
      // (the bespoke DebianPreseedInstaller it replaced was deleted). Backslash paths — DiscUtils convention.
      "unattended": {
        "kind": "initrd-inject",
        "kernelPath": "install.amd\\vmlinuz",
        "initrdPaths": ["install.amd\\initrd.gz"],
        "append": "auto=true priority=critical",
        "seedFileName": "preseed.cfg",
        "seedTemplate": "### Localization\nd-i debian-installer/locale string {locale}\nd-i keyboard-configuration/xkb-keymap select {keyboard}\n\n### Network\nd-i netcfg/choose_interface select auto\nd-i netcfg/get_hostname string {hostname}\nd-i netcfg/hostname string {hostname}\nd-i netcfg/get_domain string\n\n### Apt mirror\nd-i mirror/country string manual\nd-i mirror/http/hostname string deb.debian.org\nd-i mirror/http/directory string /debian\nd-i mirror/http/proxy string\n\n### Clock and time zone\nd-i clock-setup/utc boolean true\nd-i time/zone string {timezone}\nd-i clock-setup/ntp boolean true\n\n### Account setup (root login disabled; the user is a sudoer)\nd-i passwd/root-login boolean false\nd-i passwd/user-fullname string {username}\nd-i passwd/username string {username}\nd-i passwd/user-password-crypted password {passwordHash}\nd-i user-setup/allow-password-weak boolean true\nd-i user-setup/encrypt-home boolean false\n\n### Partitioning (guided, whole disk, LVM) — auto-confirm every write prompt\nd-i partman-auto/method string lvm\nd-i partman-lvm/device_remove_lvm boolean true\nd-i partman-md/device_remove_md boolean true\nd-i partman-lvm/confirm boolean true\nd-i partman-lvm/confirm_nooverwrite boolean true\nd-i partman-auto/choose_recipe select atomic\nd-i partman-partitioning/confirm_write_new_label boolean true\nd-i partman/choose_partition select finish\nd-i partman/confirm boolean true\nd-i partman/confirm_nooverwrite boolean true\n\n### Base system + packages\nd-i apt-setup/non-free-firmware boolean true\ntasksel tasksel/first multiselect standard, gnome-desktop\nd-i pkgsel/upgrade select none\npopularity-contest popularity-contest/participate boolean false\n\n### Boot loader\nd-i grub-installer/only_debian boolean true\nd-i grub-installer/with_other_os boolean true\nd-i grub-installer/bootdev string default\n\n### Finish — power off so Boxwright graduates the VM to a disk boot\nd-i finish-install/reboot_in_progress note\nd-i debian-installer/exit/poweroff boolean true\n"
      }
    },
    {
      "id": "fedora-44-workstation",
      "osFamily": "fedora",
      "name": "Fedora Workstation",
      "version": "44",
      "arch": "x86_64",
      "isoUrl": "https://mirrors.edge.kernel.org/fedora/releases/44/Workstation/x86_64/iso/Fedora-Workstation-Live-44-1.7.x86_64.iso",
      "sha256": "1620295f6a00c27c3208f0c00b8ece4eab1ec69b9002152d97488bf26a426ddf",
      "sizeBytes": 2851612672,
      "recommended": { "memoryMiB": 4096, "cpuCores": 2, "diskGiB": 25, "firmware": "uefi" },
      "sourceName": "Fedora Project · mirrors.edge.kernel.org",
      "requiresLicense": false,
      "notes": "Live image — boots to a trial desktop and installs interactively. For a hands-free install pick \"Fedora Workstation (netinst)\"."
    },
    {
      // Network installer (Anaconda): unattended via a kickstart injected into the installer initrd
      // (ADR-0017). A Live image can't kickstart, so unattended Fedora uses this netinst. The declarative
      // recipe below (ADR-0026) drives it through RecipeInstaller; supportsAutoinstall surfaces the
      // "Install automatically" opt-in. inst.stage2 uses the ISO volume label ({isoLabel}) — for a Fedora
      // netinst the grub.cfg's stage2 label and the volume label are the same.
      "id": "fedora-44-netinst",
      "osFamily": "fedora",
      "supportsAutoinstall": true,
      "name": "Fedora Workstation (netinst)",
      "version": "44 (netinst)",
      "arch": "x86_64",
      "isoUrl": "https://mirrors.edge.kernel.org/fedora/releases/44/Everything/x86_64/iso/Fedora-Everything-netinst-x86_64-44-1.7.iso",
      "sha256": "bd285201494dd0ba09b54d05ac707de1401668b8512a573edb5922dcf9d7067e",
      "sizeBytes": 1217329152,
      "recommended": { "memoryMiB": 4096, "cpuCores": 2, "diskGiB": 25, "firmware": "uefi" },
      "sourceName": "Fedora Project · mirrors.edge.kernel.org",
      "requiresLicense": false,
      "notes": "Network installer — needs an internet connection during installation. Unattended installs the GNOME (Workstation) desktop, so the first install downloads a lot of packages and takes a while.",
      "unattended": {
        "kind": "initrd-inject",
        "kernelPath": "images\\pxeboot\\vmlinuz",
        "initrdPaths": ["images\\pxeboot\\initrd.img"],
        "append": "inst.ks=file:/ks.cfg inst.stage2=hd:LABEL={isoLabel} inst.text",
        "seedFileName": "ks.cfg",
        "seedTemplate": "# Boxwright-generated Fedora kickstart (unattended Workstation install).\ntext\nkeyboard --vckeymap={keyboard}\nlang {locale}\ntimezone {timezone} --utc\n\n# Network (DHCP over QEMU user-mode networking).\nnetwork --bootproto=dhcp --hostname={hostname}\n\n# Install source: the netinst ISO ships no packages, so pull from the Fedora mirrors.\nurl --mirrorlist=\"https://mirrors.fedoraproject.org/mirrorlist?repo=fedora-$releasever&arch=$basearch\"\n\n# Disk: wipe disk and let Anaconda auto-partition the whole drive (creates the ESP under UEFI).\nzerombr\nclearpart --all --initlabel\nautopart\nbootloader --location=mbr\n\n# Accounts: root login disabled; the user is a sudoer (wheel). Password is a SHA-512 crypt hash.\nrootpw --lock\nuser --name={username} --groups=wheel --iscrypted --password={passwordHash}\n\n# Power off when the install finishes so Boxwright graduates the VM to a disk boot.\npoweroff\n\n%packages\n@^workstation-product-environment\n%end\n"
      }
    },
