<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Boxwright.App.ViewModels"
        x:Class="Boxwright.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="960" Height="640"
        MinWidth="700" MinHeight="460"
        WindowStartupLocation="CenterScreen"
        Title="{Binding Title}">

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,10" BorderThickness="0,0,0,1" BorderBrush="#22808080">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="20" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Refresh" Command="{Binding Vms.RefreshCommand}"
                        IsEnabled="{Binding !Vms.IsLoading}" />
            </Grid>
        </Border>

        <!-- Error banner (only when a load fails) -->
        <Border DockPanel.Dock="Top" IsVisible="{Binding Vms.HasError}" Background="#33CC3333" Padding="16,8">
            <TextBlock Text="{Binding Vms.ErrorMessage}" Foreground="#CC3333" TextWrapping="Wrap" />
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Padding="16,6" BorderThickness="0,1,0,0" BorderBrush="#22808080">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="{Binding Accelerator, StringFormat='Accelerator: {0}'}"
                           Opacity="0.7" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding VmsDirectory}" Opacity="0.5" FontSize="12"
                           HorizontalAlignment="Right" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <!-- Content: VM list (left) + detail / power controls (right) -->
        <Grid ColumnDefinitions="300,*">

            <Panel Grid.Column="0" Margin="8">
                <ListBox ItemsSource="{Binding Vms.Vms}" SelectedItem="{Binding Vms.SelectedVm}"
                         IsVisible="{Binding !Vms.IsEmpty}" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:VmListItemViewModel">
                            <Grid ColumnDefinitions="*,Auto" Margin="4">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Summary}" Opacity="0.6" FontSize="12" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding StatusText}" Opacity="0.7"
                                           FontSize="12" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel IsVisible="{Binding Vms.IsEmpty}" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Spacing="6">
                    <TextBlock Text="No VMs yet." FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="Create one to get started — coming soon." Opacity="0.6" HorizontalAlignment="Center" />
                </StackPanel>
            </Panel>

            <Border Grid.Column="1" BorderThickness="1,0,0,0" BorderBrush="#22808080" Padding="20">
                <Panel>
                    <TextBlock Text="Select a VM to manage it." Opacity="0.5"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsVisible="{Binding !Vms.HasSelection}" />

                    <ContentControl Content="{Binding Vms.SelectedVm}" IsVisible="{Binding Vms.HasSelection}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate x:DataType="vm:VmListItemViewModel">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="{Binding Name}" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Summary}" Opacity="0.6" />
                                    <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" />

                                    <Border IsVisible="{Binding HasStatusMessage}" Background="#22808080"
                                            CornerRadius="4" Padding="10">
                                        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" FontSize="12" />
                                    </Border>

                                    <WrapPanel>
                                        <Button Content="Start" Command="{Binding StartCommand}" Margin="0,0,8,8" />
                                        <Button Content="Pause" Command="{Binding PauseCommand}" Margin="0,0,8,8" />
                                        <Button Content="Resume" Command="{Binding ResumeCommand}" Margin="0,0,8,8" />
                                        <Button Content="Reset" Command="{Binding ResetCommand}" Margin="0,0,8,8" />
                                        <Button Content="Stop" Command="{Binding StopCommand}" Margin="0,0,8,8" />
                                    </WrapPanel>

                                    <StackPanel>
                                        <Button Content="Delete…" Command="{Binding DeleteCommand}"
                                                IsVisible="{Binding !IsConfirmingDelete}" />
                                        <StackPanel Orientation="Horizontal" Spacing="8"
                                                    IsVisible="{Binding IsConfirmingDelete}">
                                            <TextBlock Text="Delete this VM and its disks?" VerticalAlignment="Center"
                                                       TextWrapping="Wrap" />
                                            <Button Content="Delete" Command="{Binding ConfirmDeleteCommand}" />
                                            <Button Content="Cancel" Command="{Binding CancelDeleteCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </Panel>
            </Border>

        </Grid>

    </DockPanel>

</Window>
