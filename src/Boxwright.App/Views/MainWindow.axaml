<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Boxwright.App.ViewModels"
        xmlns:conv="using:Boxwright.App.Converters"
        xmlns:views="using:Boxwright.App.Views"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        x:Class="Boxwright.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="980" Height="660"
        MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="Mica,None"
        Icon="/Assets/boxwright.ico"
        Title="{Binding Title}">

    <DockPanel>

        <!-- Header / app bar -->
        <Border DockPanel.Dock="Top" Padding="16,10" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="20" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding BeginEditCommand}" IsEnabled="{Binding Vms.HasSelection}"
                            ToolTip.Tip="Edit the selected VM's settings">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ui:SymbolIcon Symbol="Settings" FontSize="16" /><TextBlock Text="Settings" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding Vms.RefreshCommand}" IsEnabled="{Binding !Vms.IsLoading}"
                            ToolTip.Tip="Reload the VM list from disk">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ui:SymbolIcon Symbol="Refresh" FontSize="16" /><TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OpenLogsFolderCommand}"
                            ToolTip.Tip="Open Boxwright's logs folder (app diagnostics) in your file manager">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ui:SymbolIcon Symbol="Folder" FontSize="16" /><TextBlock Text="Logs" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnToggleTheme"
                            ToolTip.Tip="Switch appearance: follow system → light → dark">
                        <ui:SymbolIcon Symbol="DarkTheme" FontSize="16" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Error banner (only when a load fails) -->
        <ui:InfoBar DockPanel.Dock="Top" IsOpen="{Binding Vms.HasError}" IsClosable="False"
                    Severity="Error" Title="Couldn't load VMs" Message="{Binding Vms.ErrorMessage}"
                    Margin="16,8,16,0" />

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Padding="16,6" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="{Binding Accelerator, StringFormat='Accelerator: {0}'}"
                           Opacity="0.7" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding VmsDirectory}" Opacity="0.5" FontSize="12"
                           HorizontalAlignment="Right" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <!-- Content: VM list (left) + detail / form (right) -->
        <Grid ColumnDefinitions="300,*">

            <!-- Sidebar: prominent New VM + the VM cards -->
            <DockPanel Grid.Column="0" Margin="12,12,6,12">
                <Button DockPanel.Dock="Top" Classes="accent" Command="{Binding BeginCreateCommand}"
                        IsEnabled="{Binding !IsShowingForm}" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="Add" FontSize="16" /><TextBlock Text="New VM" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Top" Command="{Binding BeginBrowseCatalogCommand}"
                        IsEnabled="{Binding !IsShowingForm}" HorizontalAlignment="Stretch" Margin="0,0,0,12"
                        ToolTip.Tip="Download a ready-to-install OS and create a VM for it">
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="Globe" FontSize="16" /><TextBlock Text="Get an OS" />
                    </StackPanel>
                </Button>

                <Panel>
                    <ListBox Classes="vm-list" ItemsSource="{Binding Vms.Vms}"
                             SelectedItem="{Binding Vms.SelectedVm}"
                             IsVisible="{Binding !Vms.IsEmpty}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:VmListItemViewModel">
                                <Border Classes="card" Padding="12">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}"
                                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Row="0" Grid.Column="1" Classes="pill"
                                                Background="{Binding Status, Converter={x:Static conv:StatusToBrushConverter.Instance}}">
                                            <TextBlock Text="{Binding StatusText}" />
                                        </Border>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                   Text="{Binding Summary}" Opacity="0.6" FontSize="12"
                                                   Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel IsVisible="{Binding Vms.IsEmpty}" HorizontalAlignment="Center"
                                VerticalAlignment="Center" Spacing="6" MaxWidth="240">
                        <TextBlock Text="No VMs yet" FontSize="18" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Click “New VM” to create your first virtual machine."
                                   Opacity="0.6" HorizontalAlignment="Center" TextWrapping="Wrap"
                                   TextAlignment="Center" />
                    </StackPanel>
                </Panel>
            </DockPanel>

            <!-- Right pane: new-VM form / settings form / detail / placeholder -->
            <Border Grid.Column="1" BorderThickness="1,0,0,0"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" Padding="16">
                <Panel>

                    <ContentControl Content="{Binding Creation}" IsVisible="{Binding IsCreating}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate x:DataType="vm:NewVmViewModel">
                                <views:NewVmView />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <ContentControl Content="{Binding Editing}" IsVisible="{Binding IsEditing}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate x:DataType="vm:VmSettingsViewModel">
                                <views:VmSettingsView />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <ContentControl Content="{Binding Catalog}" IsVisible="{Binding IsBrowsingCatalog}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate x:DataType="vm:CatalogViewModel">
                                <views:CatalogView />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <Panel IsVisible="{Binding !IsShowingForm}">
                        <StackPanel IsVisible="{Binding !Vms.HasSelection}" HorizontalAlignment="Center"
                                    VerticalAlignment="Center" Spacing="6" MaxWidth="280">
                            <TextBlock Text="Select a VM" FontSize="18" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Pick a virtual machine from the list to manage it."
                                       Opacity="0.5" HorizontalAlignment="Center" TextWrapping="Wrap"
                                       TextAlignment="Center" />
                        </StackPanel>

                        <ContentControl Content="{Binding Vms.SelectedVm}" IsVisible="{Binding Vms.HasSelection}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate x:DataType="vm:VmListItemViewModel">
                                    <views:VmDetailView />
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>
                    </Panel>

                </Panel>
            </Border>

        </Grid>

    </DockPanel>

</Window>
