<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Boxwright.App.ViewModels"
             xmlns:core="using:Boxwright.Core"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="Boxwright.App.Views.VmSettingsView"
             x:DataType="vm:VmSettingsViewModel">

    <ScrollViewer>
        <StackPanel Spacing="14" MaxWidth="460" HorizontalAlignment="Left" Margin="0,0,0,8">
            <TextBlock Text="VM settings" FontSize="24" FontWeight="SemiBold" />

            <ui:InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                        Message="These are boot-time settings — they take effect the next time the VM starts." />
            <ui:InfoBar IsOpen="{Binding IsRunning}" IsClosable="False" Severity="Warning"
                        Message="The VM is running. Stop and restart it to apply these changes." />

            <Border Classes="card">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Name" Opacity="0.7" />
                        <TextBox Text="{Binding Name}" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Memory (MiB)" Opacity="0.7" />
                        <TextBox Text="{Binding MemoryMiB}" Width="160" HorizontalAlignment="Left" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="CPU cores" Opacity="0.7" />
                        <TextBox Text="{Binding CpuCores}" Width="160" HorizontalAlignment="Left" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Firmware" Opacity="0.7" />
                        <ComboBox ItemsSource="{Binding FirmwareOptions}" SelectedItem="{Binding Firmware}"
                                  Width="160" HorizontalAlignment="Left" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Guest OS" Opacity="0.7" />
                        <ComboBox ItemsSource="{Binding OsTypeOptions}" SelectedItem="{Binding OsType}"
                                  Width="160" HorizontalAlignment="Left" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Display protocol" Opacity="0.7" />
                        <ComboBox ItemsSource="{Binding DisplayProtocolOptions}" SelectedItem="{Binding DisplayProtocol}"
                                  Width="160" HorizontalAlignment="Left" />
                    </StackPanel>
                    <CheckBox IsChecked="{Binding AudioEnabled}" Content="Enable audio" />
                    <CheckBox IsChecked="{Binding BootMenu}" Content="Show the firmware boot menu" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="Disks (read-only)" Opacity="0.7" />
                        <TextBlock Text="{Binding DisksText}" FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="10" DataContext="{Binding Usb}" x:DataType="vm:UsbDevicesViewModel">
                    <TextBlock Text="USB passthrough" FontWeight="SemiBold" />
                    <TextBlock Text="Pass a host USB device through to the guest (takes effect next boot)."
                               FontSize="12" Opacity="0.6" TextWrapping="Wrap" />

                    <ItemsControl ItemsSource="{Binding Devices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="core:UsbPassthroughConfig">
                                <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto" Margin="0,2">
                                    <TextBlock Grid.Column="0" Text="{Binding VendorId}" FontFamily="monospace" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding ProductId}" FontFamily="monospace" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="{Binding Description}" Margin="8,0,0,0" Opacity="0.6" VerticalAlignment="Center" />
                                    <Button Grid.Column="4" Content="Remove"
                                            Command="{Binding $parent[ItemsControl].((vm:UsbDevicesViewModel)DataContext).RemoveCommand}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6" IsVisible="{Binding CanListHost}">
                        <ComboBox Grid.Column="0" HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding HostDevices}" SelectedItem="{Binding SelectedHostDevice}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="core:HostUsbDevice">
                                    <Grid ColumnDefinitions="Auto,Auto,Auto,*">
                                        <TextBlock Grid.Column="0" Text="{Binding VendorId}" FontFamily="monospace" />
                                        <TextBlock Grid.Column="1" Text=":" />
                                        <TextBlock Grid.Column="2" Text="{Binding ProductId}" FontFamily="monospace" />
                                        <TextBlock Grid.Column="3" Text="{Binding Description}" Margin="8,0,0,0" Opacity="0.7" />
                                    </Grid>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="1" Content="Refresh" Command="{Binding LoadHostDevicesCommand}" />
                        <Button Grid.Column="2" Content="Add" Command="{Binding AddSelectedCommand}" />
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Or add by vendor:product (e.g. 046d:c52b)" Opacity="0.7" FontSize="12" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <TextBox Grid.Column="0" Text="{Binding ManualEntry}" Watermark="046d:c52b" />
                            <Button Grid.Column="1" Content="Add" Command="{Binding AddManualCommand}" />
                        </Grid>
                    </StackPanel>

                    <ui:InfoBar IsOpen="{Binding HasErrorMessage}" IsClosable="False" Severity="Warning"
                                Message="{Binding ErrorMessage}" />
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding ValidationError}" IsVisible="{Binding HasValidationError}"
                       Foreground="#CC8800" TextWrapping="Wrap" />
            <ui:InfoBar IsOpen="{Binding HasErrorMessage}" IsClosable="False" Severity="Error"
                        Message="{Binding ErrorMessage}" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Classes="accent" Content="Save" Command="{Binding SaveCommand}" />
                <Button Content="Cancel" Command="{Binding CancelCommand}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
