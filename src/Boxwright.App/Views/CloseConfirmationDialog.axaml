<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        x:Class="Boxwright.App.Views.CloseConfirmationDialog"
        Title="Close Boxwright?"
        SizeToContent="WidthAndHeight" CanResize="False" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="24" Spacing="20" Width="460">
        <Grid ColumnDefinitions="Auto,*">
            <ui:SymbolIcon Grid.Column="0" Symbol="ImportantFilled" FontSize="26"
                           Foreground="#E8920C" VerticalAlignment="Top" Margin="0,0,14,0" />
            <TextBlock Grid.Column="1" x:Name="MessageText" TextWrapping="Wrap" />
        </Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Classes="accent" Content="Shut down" Click="OnShutDown" IsDefault="True" />
            <Button Content="Force off" Click="OnForceOff" />
            <Button Content="Cancel" Click="OnCancel" IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>
