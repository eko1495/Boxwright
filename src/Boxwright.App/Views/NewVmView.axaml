<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Boxwright.App.ViewModels"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="Boxwright.App.Views.NewVmView"
             x:DataType="vm:NewVmViewModel">

    <ScrollViewer>
        <StackPanel Spacing="14" MaxWidth="460" HorizontalAlignment="Left" Margin="0,0,0,8">
            <TextBlock Text="New VM" FontSize="24" FontWeight="SemiBold" />

            <Border Classes="card">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Name" Opacity="0.7" />
                        <TextBox Text="{Binding Name}" Watermark="e.g. Ubuntu 24.04" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Memory (MiB)" Opacity="0.7" />
                        <TextBox Text="{Binding MemoryMiB}" Width="160" HorizontalAlignment="Left" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="CPU cores" Opacity="0.7" />
                        <TextBox Text="{Binding CpuCores}" Width="160" HorizontalAlignment="Left" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Disk size (GiB)" Opacity="0.7" />
                        <TextBox Text="{Binding DiskSizeGiB}" Width="160" HorizontalAlignment="Left" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Firmware" Opacity="0.7" />
                        <ComboBox ItemsSource="{Binding FirmwareOptions}" SelectedItem="{Binding Firmware}"
                                  Width="160" HorizontalAlignment="Left" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Guest OS" Opacity="0.7" />
                        <ComboBox ItemsSource="{Binding OsTypeOptions}" SelectedItem="{Binding OsType}"
                                  Width="160" HorizontalAlignment="Left" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding ValidationError}" IsVisible="{Binding HasValidationError}"
                       Foreground="#CC8800" TextWrapping="Wrap" />
            <ui:InfoBar IsOpen="{Binding HasErrorMessage}" IsClosable="False" Severity="Error"
                        Message="{Binding ErrorMessage}" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Classes="accent" Content="Create" Command="{Binding CreateCommand}" />
                <Button Content="Cancel" Command="{Binding CancelCommand}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
