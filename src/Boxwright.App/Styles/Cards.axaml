<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.PreviewWith>
        <StackPanel Width="280" Spacing="12" Margin="16">
            <Border Classes="card">
                <TextBlock Text="A card surface" />
            </Border>
        </StackPanel>
    </Design.PreviewWith>

    <!-- Rounded, theme-aware surface used for the detail sections and forms. -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- Sidebar VM list: transparent host; each row supplies its own card via the template. -->
    <Style Selector="ListBox.vm-list">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ListBox.vm-list ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>
</Styles>
